# Environment Variables for Backend

## Database
DATABASE_CONNECTION_STRING=Server=.;Database=NotesDb;Trusted_Connection=true;TrustServerCertificate=true;

## JWT Settings
JWT_SECRET_KEY=your-super-secret-key-change-in-production-now-seriously-change-this
JWT_EXPIRATION_MINUTES=60
JWT_ISSUER=NotesApplication
JWT_AUDIENCE=NotesApplicationUsers

## Application
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5000

## CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
